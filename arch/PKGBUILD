# Maintainer: Piotr Mikstacki <piotr@beskid-lang.org>
# AUR package: beskid-bin
#
# This PKGBUILD installs the prebuilt Beskid CLI + LSP for x86_64 Linux from the
# rolling cli-latest / lsp-latest release on beskid_compiler. The version and
# sha256sums are stamped by the arch-aur CI job before
# KSXGitHub/github-actions-deploy-aur pushes to the AUR.
#
# Users install via:  yay -S beskid-bin   (or any AUR helper)

pkgname=beskid-bin
pkgver=__VERSION__
pkgrel=1
pkgdesc="Beskid compiler CLI and LSP (AOT, host composition) — prebuilt binaries"
arch=('x86_64')
url="https://beskid-lang.org"
license=('MIT')
provides=('beskid' 'beskid-lsp')
conflicts=('beskid' 'beskid-git')
source_x86_64=("beskid-linux-amd64::https://github.com/Cyber-Nomad-Collective/beskid_compiler/releases/download/cli-latest/beskid-linux-amd64"
               "beskid_lsp-linux-amd64::https://github.com/Cyber-Nomad-Collective/beskid_compiler/releases/download/lsp-latest/beskid_lsp-linux-amd64")
sha256sums_x86_64=('__CLI_SHA256__'
                   '__LSP_SHA256__')

package() {
    install -Dm755 "${srcdir}/beskid-linux-amd64" "${pkgdir}/usr/bin/beskid"
    install -Dm755 "${srcdir}/beskid_lsp-linux-amd64" "${pkgdir}/usr/bin/beskid_lsp"
}
